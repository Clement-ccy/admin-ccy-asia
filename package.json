{
  "name": "admin-ccy-asia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run migrate:api:local && wrangler dev --config worker/wrangler.jsonc",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:api:local": "wrangler d1 migrations apply pf-database --local --config worker/wrangler.jsonc",
    "migrate:api:remote": "wrangler d1 migrations apply pf-database --remote --config worker/wrangler.jsonc",
    "deploy:api": "wrangler deploy --config worker/wrangler.jsonc"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.5",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "wrangler": "^4.70.0"
  }
}
